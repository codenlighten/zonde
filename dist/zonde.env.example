# zonde configuration — copy to /etc/zonde/zonde.env and uncomment as needed.
# Precedence: process flags > these env vars > built-in defaults.

# Address and port for the /metrics HTTP endpoint (pull mode).
#ZONDE_LISTEN_ADDR=0.0.0.0
#ZONDE_PORT=9100

# Set an OTLP endpoint to switch to push (agent) mode instead of serving.
#ZONDE_OTLP_ENDPOINT=http://collector:4318/v1/metrics
#ZONDE_INTERVAL=60
